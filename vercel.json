{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data: https://ofmmwcjhdrhvxxkhcuww.supabase.co https://*.unsplash.com; connect-src 'self' https://ofmmwcjhdrhvxxkhcuww.supabase.co https://msg.moonraker.ai; frame-ancestors 'self'" }
      ]
    },
    {
      "source": "/:slug/img/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/favicon.ico", "destination": "/assets/logo.png" },
    { "source": "/:slug/img/:path*", "destination": "https://ofmmwcjhdrhvxxkhcuww.supabase.co/storage/v1/object/public/images/:slug/:path*" }
  ],
  "functions": {
    "api/activate-reporting.js": { "maxDuration": 120, "memory": 1024 },
    "api/bootstrap-access.js": { "maxDuration": 120, "memory": 1024 },
    "api/chat.js": { "maxDuration": 120, "memory": 1024 },
    "api/compile-report.js": { "maxDuration": 300, "memory": 1024 },
    "api/digest.js": { "maxDuration": 120, "memory": 1024 },
    "api/enrich-proposal.js": { "maxDuration": 120, "memory": 1024 },
    "api/generate-content-page.js": { "maxDuration": 120, "memory": 1024 },
    "api/generate-proposal.js": { "maxDuration": 300, "memory": 1024 },
    "api/newsletter-generate.js": { "maxDuration": 300, "memory": 1024 },
    "api/newsletter-research.js": { "maxDuration": 300, "memory": 1024 },
    "api/process-entity-audit.js": { "maxDuration": 300, "memory": 1024 },
    "api/report-chat.js": { "maxDuration": 120, "memory": 1024 },
    "api/send-newsletter.js": { "maxDuration": 120, "memory": 1024 },
    "api/agreement-chat.js": { "maxDuration": 120 },
    "api/content-chat.js": { "maxDuration": 120 },
    "api/proposal-chat.js": { "maxDuration": 120 },
    "api/seed-batch-audits.js": { "maxDuration": 120 },
    "api/cron/process-queue.js": { "maxDuration": 300, "memory": 1024 },
    "api/cron/process-batch-pages.js": { "maxDuration": 120, "memory": 1024 }
  },
  "crons": [
    { "path": "/api/cron/enqueue-reports", "schedule": "0 10 1 * *" },
    { "path": "/api/cron/process-queue", "schedule": "*/5 * * * *" },
    { "path": "/api/cron/process-followups", "schedule": "0 14 * * *" },
    { "path": "/api/cron/trigger-quarterly-audits", "schedule": "0 11 * * *" },
    { "path": "/api/cron/process-audit-queue", "schedule": "*/30 * * * *" },
    { "path": "/api/cron/process-scheduled-sends", "schedule": "*/5 * * * *" },
    { "path": "/api/cron/process-batch-pages", "schedule": "*/5 * * * *" }
  ]
}

