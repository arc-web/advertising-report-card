{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ],
  "functions": {
    "api/chat.js": {
      "maxDuration": 120,
      "memory": 1024
    },
    "api/action.js": {
      "maxDuration": 30
    }
  }
}
