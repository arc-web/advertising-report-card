{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/favicon.ico",
      "destination": "/assets/logo.png"
    }
  ],
  "functions": {
    "api/chat.js": {
      "maxDuration": 120,
      "memory": 1024,
      "supportsResponseStreaming": true
    },
    "api/action.js": {
      "maxDuration": 30
    },
    "api/convert-to-prospect.js": {
      "maxDuration": 60
    },
    "api/process-entity-audit.js": {
      "maxDuration": 120,
      "memory": 1024
    },
    "api/delete-client.js": {
      "maxDuration": 60
    },
    "api/compile-report.js": {
      "maxDuration": 300,
      "memory": 1024
    },
    "api/send-report-email.js": {
      "maxDuration": 30
    },
    "api/bootstrap-access.js": {
      "maxDuration": 120,
      "memory": 1024
    },
    "api/discover-services.js": {
      "maxDuration": 60
    },
    "api/cron/enqueue-reports.js": {
      "maxDuration": 30
    },
    "api/cron/process-queue.js": {
      "maxDuration": 300,
      "memory": 1024
    },
    "api/enrich-proposal.js": {
      "maxDuration": 120,
      "memory": 1024
    },
    "api/generate-proposal.js": {
      "maxDuration": 300,
      "memory": 1024
    },
    "api/send-proposal-email.js": {
      "maxDuration": 30
    },
    "api/proposal-chat.js": {
      "maxDuration": 120
    },
    "api/delete-proposal.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/enqueue-reports",
      "schedule": "0 10 1 * *"
    },
    {
      "path": "/api/cron/process-queue",
      "schedule": "*/5 * * * *"
    }
  ]
}

