import { useState } from "react";

const GH_TOKEN = "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";
const REPO = "Moonraker-AI/moonraker-insights";
const FILE_PATH = "elizabeth-morrison/proposal/index.html";
const BRANCH = "main";

export default function GitHubPush() {
  const [status, setStatus] = useState("ready");
  const [message, setMessage] = useState("");
  const [liveUrl, setLiveUrl] = useState("");

  async function pushToGitHub() {
    setStatus("pushing");
    setMessage("Fetching proposal HTML...");

    try {
      // First check if file already exists to get SHA
      let sha = null;
      try {
        const checkResp = await fetch(
          `https://api.github.com/repos/${REPO}/contents/${FILE_PATH}?ref=${BRANCH}`,
          { headers: { Authorization: `Bearer ${GH_TOKEN}`, Accept: "application/vnd.github+json" } }
        );
        if (checkResp.ok) {
          const existing = await checkResp.json();
          sha = existing.sha;
          setMessage("File exists, will update...");
        }
      } catch (e) { /* file doesn't exist yet, that's fine */ }

      setMessage("Reading proposal content from artifact iframe...");

      // The proposal HTML content - we need to fetch it from the other artifact
      // Since we can't cross-reference artifacts, we'll use the content directly
      const proposalResp = await fetch(
        `https://raw.githubusercontent.com/${REPO}/${BRANCH}/_templates/proposal.html`,
        { headers: { Authorization: `Bearer ${GH_TOKEN}` } }
      );

      // We actually need to push our custom content. Let me encode it inline.
      // The full proposal HTML is too large for inline, so let's fetch the proposal artifact content
      // via a different approach - we'll use window.parent to access it

      setMessage("Encoding content...");

      // Build the payload
      const content = await getProposalContent();
      const base64Content = btoa(unescape(encodeURIComponent(content)));

      const payload = {
        message: "Add Elizabeth Morrison proposal",
        content: base64Content,
        branch: BRANCH,
      };
      if (sha) payload.sha = sha;

      setMessage("Pushing to GitHub...");

      const resp = await fetch(
        `https://api.github.com/repos/${REPO}/contents/${FILE_PATH}`,
        {
          method: "PUT",
          headers: {
            Authorization: `Bearer ${GH_TOKEN}`,
            Accept: "application/vnd.github+json",
            "Content-Type": "application/json",
          },
          body: JSON.stringify(payload),
        }
      );

      if (!resp.ok) {
        const err = await resp.text();
        throw new Error(`GitHub API error ${resp.status}: ${err}`);
      }

      const result = await resp.json();
      setStatus("success");
      setLiveUrl("https://insights.moonraker.ai/elizabeth-morrison/proposal");
      setMessage(`Pushed successfully! Commit: ${result.commit?.sha?.slice(0, 7)}`);
    } catch (err) {
      setStatus("error");
      setMessage(`Error: ${err.message}`);
    }
  }

  async function getProposalContent() {
    // Return the full proposal HTML
    return PROPOSAL_HTML;
  }

  return (
    <div className="min-h-screen bg-gray-950 text-white p-8 flex flex-col items-center justify-center">
      <div className="max-w-lg w-full">
        <h1 className="text-2xl font-bold mb-2 text-emerald-400">Push Proposal to GitHub</h1>
        <p className="text-gray-400 mb-1 text-sm">Repo: {REPO}</p>
        <p className="text-gray-400 mb-1 text-sm">Path: {FILE_PATH}</p>
        <p className="text-gray-400 mb-6 text-sm">Branch: {BRANCH}</p>

        {status === "ready" && (
          <button
            onClick={pushToGitHub}
            className="w-full bg-emerald-500 hover:bg-emerald-400 text-white font-semibold py-3 px-6 rounded-lg transition-colors"
          >
            Push Elizabeth Morrison Proposal to GitHub
          </button>
        )}

        {status === "pushing" && (
          <div className="bg-gray-900 border border-gray-700 rounded-lg p-4">
            <div className="flex items-center gap-3">
              <div className="w-5 h-5 border-2 border-emerald-400 border-t-transparent rounded-full animate-spin" />
              <span className="text-gray-300">{message}</span>
            </div>
          </div>
        )}

        {status === "success" && (
          <div className="bg-gray-900 border border-emerald-600 rounded-lg p-4 space-y-3">
            <div className="flex items-center gap-2 text-emerald-400 font-semibold">
              <span>&#10003;</span> {message}
            </div>
            {liveUrl && (
              <a
                href={liveUrl}
                target="_blank"
                rel="noopener"
                className="block text-center bg-emerald-500 hover:bg-emerald-400 text-white font-semibold py-3 px-6 rounded-lg transition-colors"
              >
                View Live Proposal &rarr;
              </a>
            )}
            <p className="text-gray-400 text-xs text-center">Auto-deploys via Vercel in 30-60 seconds</p>
          </div>
        )}

        {status === "error" && (
          <div className="bg-gray-900 border border-red-600 rounded-lg p-4 space-y-3">
            <p className="text-red-400">{message}</p>
            <button
              onClick={() => { setStatus("ready"); setMessage(""); }}
              className="w-full bg-gray-700 hover:bg-gray-600 text-white font-semibold py-2 px-4 rounded-lg transition-colors"
            >
              Try Again
            </button>
          </div>
        )}
      </div>
    </div>
  );
}

